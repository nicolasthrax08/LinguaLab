# Supabase project credentials (free tier)
# Create a project at https://supabase.com and copy these from Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter API key
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: uncomment to use deterministic mock replies instead of OpenRouter.
# Useful for hackathon demos if the API quota is exceeded.
# MOCK_CHAT=true
