# Supabase project credentials (free tier)
# Create a project at https://supabase.com and copy these from Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini API key (free tier available)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional: uncomment to use deterministic mock replies instead of Gemini.
# Useful for hackathon demos if the API quota is exceeded.
# MOCK_CHAT=true
